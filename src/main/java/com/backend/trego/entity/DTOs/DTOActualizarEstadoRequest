package com.backend.trego.entity.DTOs;

import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonProperty;

public class DTOActualizarEstadoRequest {
    
    // Al ser 'final', garantizamos la inmutabilidad: nacen con un valor y nunca cambian
    private final DTOPedido pedido;
    private final String estado;

    // Le indicamos a Spring Boot cómo construir este objeto desde el JSON
    @JsonCreator
    public DTOActualizarEstadoRequest(
            @JsonProperty("pedido") DTOPedido pedido,
            @JsonProperty("estado") String estado) {
        this.pedido = pedido;
        this.estado = estado;
    }

    // Solo métodos de lectura (Getters)
    public DTOPedido getPedido() { 
        return pedido; 
    }
    
    public String getEstado() { 
        return estado; 
    }
}
